<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>PH Healthcare Invoice</title>

<style>
  body {
    margin: 0;
    background: #F3F6F9;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: #1F2937;
  }

  .container {
    max-width: 640px;
    margin: 30px auto;
    background: #ffffff;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #E5E7EB;
  }

  /* HEADER */
  .header {
    padding: 28px 32px;
    border-bottom: 1px solid #E5E7EB;
  }

  .brand {
    font-size: 18px;
    font-weight: 700;
    color: #0F172A;
  }

  .invoice-title {
    font-size: 22px;
    font-weight: 700;
    margin-top: 8px;
  }

  .meta {
    float: right;
    text-align: right;
    font-size: 12px;
    color: #6B7280;
  }

  /* CONTENT */
  .content {
    padding: 32px;
  }

  .greeting {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .subtext {
    font-size: 14px;
    color: #6B7280;
    margin-bottom: 24px;
  }

  /* CARD */
  .card {
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
  }

  .row {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    margin-bottom: 10px;
  }

  .label {
    color: #6B7280;
  }

  .value {
    font-weight: 600;
    color: #111827;
  }

  .paid {
    color: #059669;
    font-weight: 700;
  }

  /* GRID */
  .grid {
    display: flex;
    gap: 16px;
  }

  .grid .card {
    flex: 1;
  }

  /* AMOUNT */
  .amount-box {
    background: #0EA5A4;
    color: white;
    padding: 24px;
    border-radius: 10px;
    text-align: center;
    margin: 25px 0;
  }

  .amount-box p {
    font-size: 13px;
    opacity: 0.9;
  }

  .amount-box h2 {
    font-size: 32px;
    margin-top: 6px;
  }

  /* BUTTON */
  .btn {
    display: inline-block;
    background: #0F172A;
    color: white;
    padding: 12px 24px;
    border-radius: 6px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
  }

  .btn:hover {
    background: #020617;
  }

  .center {
    text-align: center;
    margin-top: 20px;
  }

  /* FOOTER */
  .footer {
    text-align: center;
    padding: 24px;
    font-size: 12px;
    color: #9CA3AF;
    border-top: 1px solid #E5E7EB;
  }

</style>
</head>

<body>

<div class="container">

  <!-- HEADER -->
  <div class="header">
    <div class="meta">
      Invoice ID<br />
      <strong><%= invoiceId %></strong><br /><br />
      Payment Date<br />
      <strong><%= paymentDate %></strong>
    </div>

    <div class="brand">PH Healthcare</div>
    <div class="invoice-title">Payment Invoice</div>
  </div>

  <!-- CONTENT -->
  <div class="content">

    <div class="greeting">Hello <%= patientName %>,</div>
    <div class="subtext">
      Your payment has been successfully processed. Here are your invoice details.
    </div>

    <!-- INFO -->
    <div class="card">
      <div class="row">
        <span class="label">Transaction ID</span>
        <span class="value"><%= transactionId %></span>
      </div>
      <div class="row">
        <span class="label">Status</span>
        <span class="paid">PAID ✓</span>
      </div>
    </div>

    <!-- DETAILS -->
    <div class="grid">
      <div class="card">
        <div class="label">Doctor</div>
        <div class="value"><%= doctorName %></div>
      </div>

      <div class="card">
        <div class="label">Appointment</div>
        <div class="value"><%= appointmentDate %></div>
      </div>
    </div>

    <!-- AMOUNT -->
    <div class="amount-box">
      <p>Total Amount Paid</p>
      <h2><%= amount.toFixed(2) %> BDT</h2>
    </div>

    <!-- BUTTON -->
    <% if (invoiceUrl) { %>
    <div class="center">
      <a href="<%= invoiceUrl %>" class="btn">Download Invoice</a>
    </div>
    <% } %>

  </div>

  <!-- FOOTER -->
  <div class="footer">
    PH Healthcare • Your Health, Our Priority<br />
    support@ph-healthcare.com
  </div>

</div>

</body>
</html>